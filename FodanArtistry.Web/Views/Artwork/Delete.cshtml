@model FodanArtistry.Application.DTOs.ArtworkModel.ArtworkDto
@{
    ViewData["Title"] = "Delete Artwork - Fodan Artistry";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Confirm Delete</h4>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <i class="bi bi-exclamation-triangle display-1 text-danger"></i>
                    </div>
                    
                    <h5 class="text-center mb-4">Are you sure you want to delete this artwork?</h5>
                    
                    <div class="alert alert-warning">
                        <p><strong>Title:</strong> @Model.Title</p>
                        <p><strong>Artist:</strong> @Model.ArtistName</p>
                        <p><strong>Price:</strong> @Model.Price.ToString("C")</p>
                        <p><strong>Category:</strong> @Model.CategoryName</p>
                        <p class="mb-0">
                            <strong>Status:</strong>
                            <span class="badge bg-@(Model.IsAvailable ? "success" : "danger")">
                                @(Model.IsAvailable ? "Available" : "Sold")
                            </span>
                        </p>
                    </div>

                    <p class="text-danger small mb-4">
                        <i class="bi bi-info-circle"></i>
                        This action cannot be undone. The artwork will be permanently removed.
                    </p>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <form asp-action="Delete" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="bi bi-trash"></i> Delete Permanently
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>