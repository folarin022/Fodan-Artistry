@model FodanArtistry.Application.DTOs.ArtworkModel.ArtworkDto

@{
    ViewData["Title"] = $"{Model.Title} - Fodan Artistry";
    var isFavorited = ViewBag.IsFavorited ?? false;
    var relatedArtworks = ViewBag.RelatedArtworks as IEnumerable<FodanArtistry.Application.DTOs.ArtworkModel.ArtworkDto> 
                         ?? new List<FodanArtistry.Application.DTOs.ArtworkModel.ArtworkDto>();
}

<!-- Breadcrumb -->
<nav class="bg-light py-3">
    <div class="container">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Gallery" class="text-decoration-none">Gallery</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </div>
</nav>

<!-- Artwork Details -->
<section class="py-5">
    <div class="container">
        <div class="row g-5">
            <!-- Image Gallery -->
            <div class="col-lg-7">
                <div class="position-relative">
                    <img src="@Model.ImageUrl" class="img-fluid rounded-4 shadow-lg w-100" alt="@Model.Title" 
                         style="max-height: 600px; object-fit: cover;"
                         id="mainImage">
                    
                    @if (!Model.IsAvailable)
                    {
                        <div class="position-absolute top-0 end-0 m-4">
                            <span class="badge bg-danger px-4 py-3 fs-6 rounded-pill">SOLD</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Artwork Info -->
            <div class="col-lg-5">
                <div class="sticky-top" style="top: 2rem;">
                    <div class="mb-4">
                        <span class="badge bg-primary px-3 py-2 rounded-pill mb-3">@Model.CategoryName</span>
                        <h1 class="display-5 fw-bold mb-3">@Model.Title</h1>
                        
                        <div class="d-flex align-items-center mb-4">
                            <div class="artist-avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3"
                                 style="width: 60px; height: 60px; font-size: 1.5rem;">
                                @Model.ArtistName?.Substring(0, 1)
                            </div>
                            <div>
                                <span class="text-muted d-block">Artist</span>
                                <a asp-action="Artist" asp-route-artistId="@Model.ArtistId" 
                                   class="h4 text-decoration-none text-dark fw-bold">
                                    @Model.ArtistName
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h3 class="h2 text-primary fw-bold mb-0">@Model.Price.ToString("C")</h3>
                        <div class="d-flex align-items-center mt-2">
                            <i class="bi bi-heart-fill text-danger me-1"></i>
                            <span id="favoriteCount" class="fw-semibold">@Model.FavoriteCount</span>
                            <span class="text-muted ms-2">people favorited this</span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h5 class="fw-bold mb-3">Description</h5>
                        <p class="text-muted lead" style="line-height: 1.8;">@Model.Description</p>
                    </div>

                    <div class="mb-4">
                        <h5 class="fw-bold mb-3">Details</h5>
                        <ul class="list-unstyled">
                            <li class="mb-2">
                                <i class="bi bi-calendar-check text-primary me-2"></i>
                                <strong>Created:</strong> @Model.CreatedAt.ToString("MMMM dd, yyyy")
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-person text-primary me-2"></i>
                                <strong>Artist:</strong> @Model.ArtistName
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-tag text-primary me-2"></i>
                                <strong>Category:</strong> @Model.CategoryName
                            </li>
                        </ul>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex gap-3 mb-4">
                        @if (Model.IsAvailable)
                        {
                            <a asp-controller="Order" asp-action="Checkout" asp-route-artworkId="@Model.Id" 
                               class="btn btn-primary btn-lg flex-grow-1 rounded-pill py-3">
                                <i class="bi bi-cart-check"></i> Purchase Now
                            </a>
                        }

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <button id="favoriteBtn" class="btn btn-outline-danger btn-lg rounded-pill px-4" 
                                    onclick="toggleFavorite()">
                                <i class="bi bi-heart@(isFavorited ? "-fill" : "") fs-5"></i>
                            </button>
                        }

                        @if (User.IsInRole("Admin") || (User.IsInRole("Artist") && Model.ArtistId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value))
                        {
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@Model.Id" 
                                   class="btn btn-outline-warning btn-lg rounded-pill px-4">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-outline-danger btn-lg rounded-pill px-4" 
                                        onclick="confirmDelete()">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        }
                    </div>

                    <!-- Share -->
                    <div class="border-top pt-4">
                        <h6 class="fw-bold mb-3">Share this artwork</h6>
                        <div class="d-flex gap-2">
                            <a href="#" class="btn btn-outline-primary rounded-circle p-3">
                                <i class="bi bi-facebook"></i>
                            </a>
                            <a href="#" class="btn btn-outline-info rounded-circle p-3">
                                <i class="bi bi-twitter"></i>
                            </a>
                            <a href="#" class="btn btn-outline-danger rounded-circle p-3">
                                <i class="bi bi-pinterest"></i>
                            </a>
                            <a href="#" class="btn btn-outline-secondary rounded-circle p-3">
                                <i class="bi bi-link"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Related Artworks -->
@if (relatedArtworks.Any())
{
    <section class="py-5 bg-light">
        <div class="container">
            <h2 class="display-6 fw-bold text-center mb-5">You Might Also Like</h2>
            <div class="row g-4">
                @foreach (var related in relatedArtworks)
                {
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm h-100 hover-lift">
                            <img src="@related.ImageUrl" class="card-img-top" alt="@related.Title" 
                                 style="height: 200px; object-fit: cover;">
                            <div class="card-body">
                                <h6 class="card-title fw-bold">@related.Title</h6>
                                <p class="text-muted small mb-2">by @related.ArtistName</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold text-primary">@related.Price.ToString("C")</span>
                                    <a asp-action="Details" asp-route-id="@related.Id" 
                                       class="btn btn-sm btn-outline-primary rounded-pill">
                                        View <i class="bi bi-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Delete Artwork</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong>@Model.Title</strong>?</p>
                <p class="text-danger">This action cannot be undone and will remove all associated data.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">Delete Permanently</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleFavorite() {
            $.ajax({
                url: '@Url.Action("ToggleFavorite", "Artwork")',
                type: 'POST',
                data: { artworkId: '@Model.Id' },
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                success: function(response) {
                    if (response.success) {
                        var btn = $('#favoriteBtn');
                        var icon = btn.find('i');
                        if (response.isFavorited) {
                            icon.removeClass('bi-heart').addClass('bi-heart-fill');
                        } else {
                            icon.removeClass('bi-heart-fill').addClass('bi-heart');
                        }
                        $('#favoriteCount').text(response.favoriteCount);
                        
                        // Show toast notification
                        showToast(response.isFavorited ? 'Added to favorites!' : 'Removed from favorites');
                    }
                }
            });
        }

        function confirmDelete() {
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }

        function showToast(message) {
            // Simple toast implementation
            var toast = `
                <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
                    <div class="toast show" role="alert">
                        <div class="toast-body bg-success text-white rounded">
                            ${message}
                        </div>
                    </div>
                </div>
            `;
            $('body').append(toast);
            setTimeout(() => $('.toast').parent().remove(), 3000);
        }

        // Image zoom on hover
        $('#mainImage').hover(
            function() { $(this).css('transform', 'scale(1.02)'); },
            function() { $(this).css('transform', 'scale(1)'); }
        );
    </script>
}

<style>
    .artist-avatar {
        transition: transform 0.3s;
    }
    .artist-avatar:hover {
        transform: scale(1.1);
    }
    .hover-lift {
        transition: transform 0.3s, box-shadow 0.3s;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.15) !important;
    }
    #mainImage {
        transition: transform 0.3s;
    }
</style>