@model IEnumerable<FodanArtistry.Application.DTOs.CategoryModel.CategoryWithCountDto>
@{
    ViewData["Title"] = "Category Management";
}

<!-- Page Header -->
<section class="page-header mb-4">
    <div class="container-fluid px-4">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="display-6 fw-bold gradient-text mb-2">Category Management</h1>
                <p class="text-muted mb-0">Organize your artworks with categories</p>
            </div>
            <div class="col-md-6 text-md-end">
                <button type="button" class="btn btn-primary btn-lg rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#createCategoryModal">
                    <i class="bi bi-plus-circle me-2"></i>Add New Category
                </button>
            </div>
        </div>
    </div>
</section>

<!-- Categories Card -->
<div class="container-fluid px-4">
    <div class="card border-0 shadow-lg">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-tags-fill text-primary me-2"></i>
                    All Categories
                </h5>
                <div class="category-stats">
                    <span class="badge bg-light text-dark me-2">
                        <i class="bi bi-grid-fill text-primary me-1"></i>
                        @Model.Count() Total
                    </span>
                    <span class="badge bg-light text-dark">
                        <i class="bi bi-palette-fill text-success me-1"></i>
                        @Model.Sum(c => c.ArtworkCount) Artworks
                    </span>
                </div>
            </div>
        </div>
        <div class="card-body p-4">
            @if (!Model.Any())
            {
                <div class="empty-state text-center py-5">
                    <div class="empty-state-icon mb-4">
                        <i class="bi bi-tags display-1 text-muted"></i>
                    </div>
                    <h4 class="fw-bold mb-3">No Categories Found</h4>
                    <p class="text-muted mb-4">Create your first category to start organizing artworks</p>
                    <button type="button" class="btn btn-primary btn-lg rounded-pill px-5" data-bs-toggle="modal" data-bs-target="#createCategoryModal">
                        <i class="bi bi-plus-circle me-2"></i>Create First Category
                    </button>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle" id="categoriesTable">
                        <thead class="bg-light">
                            <tr>
                                <th>Category</th>
                                <th>Description</th>
                                <th class="text-center">Artworks</th>
                                <th class="text-center">Available</th>
                                <th>Latest Activity</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var category in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="category-icon me-3">
                                                @if (!string.IsNullOrEmpty(category.CoverImageUrl))
                                                {
                                                    <img src="@category.CoverImageUrl" alt="@category.Name" 
                                                         class="rounded-3" width="40" height="40" style="object-fit: cover;">
                                                }
                                                else
                                                {
                                                    <div class="icon-placeholder bg-primary bg-opacity-10 text-primary rounded-3 d-flex align-items-center justify-content-center"
                                                         style="width: 40px; height: 40px;">
                                                        <i class="bi bi-tag"></i>
                                                    </div>
                                                }
                                            </div>
                                            <div>
                                                <div class="fw-semibold">@category.Name</div>
                                                <small class="text-muted">ID: @category.Id.ToString().Substring(0, 8)</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(category.Description))
                                        {
                                            <span class="description-text">@category.Description</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">No description</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill">
                                            <i class="bi bi-grid-fill me-1"></i>
                                            @category.ArtworkCount
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill">
                                            <i class="bi bi-check-circle-fill me-1"></i>
                                            @category.AvailableArtworkCount
                                        </span>
                                    </td>
                                    <td>
                                        @if (category.LatestArtworkDate.HasValue)
                                        {
                                            <div class="latest-activity">
                                                <i class="bi bi-clock-history text-primary me-1"></i>
                                                <small>@category.LatestArtworkDate.Value.ToString("MMM dd, yyyy")</small>
                                            </div>
                                        }
                                        else
                                        {
                                            <small class="text-muted">No artworks yet</small>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="action-buttons">
                                            <button class="btn btn-sm btn-outline-primary rounded-pill px-3 me-2" 
                                                    onclick="editCategory('@category.Id', '@category.Name', '@category.Description')"
                                                    title="Edit Category">
                                                <i class="bi bi-pencil me-1"></i>Edit
                                            </button>
                                            
                                            @if (category.ArtworkCount > 0)
                                            {
                                                <span class="d-inline-block" tabindex="0" data-bs-toggle="tooltip" 
                                                      title="Cannot delete - has @category.ArtworkCount artwork(s)">
                                                    <button class="btn btn-sm btn-outline-danger rounded-pill px-3" disabled>
                                                        <i class="bi bi-trash me-1"></i>Delete
                                                    </button>
                                                </span>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-danger rounded-pill px-3" 
                                                        onclick="deleteCategory('@category.Id', '@category.Name')"
                                                        title="Delete Category">
                                                    <i class="bi bi-trash me-1"></i>Delete
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        @if (Model.Any())
        {
            <div class="card-footer bg-transparent border-0 pb-4 px-4">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <p class="text-muted small mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            Showing @Model.Count() categories • @Model.Sum(c => c.ArtworkCount) total artworks
                        </p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <nav aria-label="Category pagination">
                            <ul class="pagination pagination-sm justify-content-md-end mb-0">
                                <li class="page-item disabled">
                                    <a class="page-link" href="#" tabindex="-1">Previous</a>
                                </li>
                                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                                <li class="page-item"><a class="page-link" href="#">2</a></li>
                                <li class="page-item"><a class="page-link" href="#">3</a></li>
                                <li class="page-item">
                                    <a class="page-link" href="#">Next</a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Create Category Modal (Premium) -->
<div class="modal fade" id="createCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-gradient-primary text-white border-0">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle me-2"></i>
                    Create New Category
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateCategory" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Category Name <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0">
                                <i class="bi bi-tag text-primary"></i>
                            </span>
                            <input type="text" name="Name" class="form-control border-0 bg-light" 
                                   placeholder="e.g., Paintings" required maxlength="50" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea name="Description" class="form-control border-0 bg-light" 
                                  rows="3" placeholder="Describe this category..." maxlength="200"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-primary rounded-pill px-5">
                        <i class="bi bi-check-circle me-2"></i>Create
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Category Modal (Premium) -->
<div class="modal fade" id="editCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-gradient-warning text-white border-0">
                <h5 class="modal-title">
                    <i class="bi bi-pencil-square me-2"></i>
                    Edit Category
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateCategory" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editCategoryId" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Category Name <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0">
                                <i class="bi bi-tag text-primary"></i>
                            </span>
                            <input type="text" name="Name" id="editCategoryName" class="form-control border-0 bg-light" 
                                   required maxlength="50" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea name="Description" id="editCategoryDescription" class="form-control border-0 bg-light" 
                                  rows="3" maxlength="200"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-warning rounded-pill px-5">
                        <i class="bi bi-save me-2"></i>Update
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Category Modal (Premium) -->
<div class="modal fade" id="deleteCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-gradient-danger text-white border-0">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Delete Category
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <div class="delete-icon mb-4">
                    <i class="bi bi-trash-fill display-1 text-danger"></i>
                </div>
                <h5 class="fw-bold mb-3">Are you sure?</h5>
                <p class="text-muted mb-4">
                    You are about to delete category: <strong class="text-danger" id="deleteCategoryName"></strong>
                </p>
                <p class="small text-danger bg-danger bg-opacity-10 p-3 rounded-3">
                    <i class="bi bi-info-circle me-2"></i>
                    This action cannot be undone.
                </p>
            </div>
            <div class="modal-footer border-0 bg-light justify-content-center">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">
                    Cancel
                </button>
                <form asp-action="DeleteCategory" method="post" id="deleteCategoryForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteCategoryId" />
                    <button type="submit" class="btn btn-danger rounded-pill px-5">
                        <i class="bi bi-trash me-2"></i>Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            tooltipTriggerList.map(function(tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            });

            // Search functionality
            $("#searchCategories").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#categoriesTable tbody tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });

        function editCategory(id, name, description) {
            document.getElementById('editCategoryId').value = id;
            document.getElementById('editCategoryName').value = name;
            document.getElementById('editCategoryDescription').value = description || '';
            
            var editModal = new bootstrap.Modal(document.getElementById('editCategoryModal'));
            editModal.show();
        }

        function deleteCategory(id, name) {
            document.getElementById('deleteCategoryId').value = id;
            document.getElementById('deleteCategoryName').textContent = name;
            
            var deleteModal = new bootstrap.Modal(document.getElementById('deleteCategoryModal'));
            deleteModal.show();
        }

        // Auto-dismiss alerts
        window.setTimeout(function() {
            $(".alert").fadeOut(500, function() {
                $(this).remove();
            });
        }, 5000);
    </script>
}

<style>
    .gradient-text {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .page-header {
        padding: 1.5rem 0;
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .bg-gradient-warning {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }

    .bg-gradient-danger {
        background: linear-gradient(135deg, #f54ea2 0%, #ff7676 100%);
    }

    .category-icon {
        transition: transform 0.3s;
    }

    .category-icon:hover {
        transform: scale(1.1);
    }

    .icon-placeholder {
        transition: all 0.3s;
    }

    .icon-placeholder:hover {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
        color: white !important;
    }

    .description-text {
        max-width: 250px;
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .badge {
        font-weight: 500;
        transition: all 0.3s;
    }

    .badge:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .action-buttons {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 0.5rem;
    }

    .action-buttons .btn {
        transition: all 0.3s;
    }

    .action-buttons .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .btn-outline-primary:hover {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-color: transparent;
    }

    .btn-outline-danger:hover {
        background: linear-gradient(135deg, #f54ea2 0%, #ff7676 100%);
        border-color: transparent;
        color: white;
    }

    .modal-content {
        border-radius: 20px;
    }

    .modal-header {
        border-radius: 20px 20px 0 0;
        padding: 1.5rem;
    }

    .modal-body {
        padding: 2rem;
    }

    .modal-footer {
        border-radius: 0 0 20px 20px;
        padding: 1.5rem;
    }

    .input-group-text {
        border-radius: 12px 0 0 12px;
    }

    .form-control, .form-select {
        border-radius: 0 12px 12px 0;
    }

    .delete-icon {
        animation: shake 0.5s ease-in-out;
    }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
        20%, 40%, 60%, 80% { transform: translateX(5px); }
    }

    .empty-state-icon i {
        animation: float 3s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    .page-link {
        border: none;
        padding: 0.5rem 1rem;
        margin: 0 0.25rem;
        border-radius: 10px;
        color: #6c757d;
        transition: all 0.3s;
    }

    .page-link:hover {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        transform: translateY(-2px);
    }

    .page-item.active .page-link {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .page-header .col-md-6 {
            text-align: center !important;
            margin-bottom: 1rem;
        }

        .action-buttons {
            flex-direction: column;
            align-items: flex-start;
        }

        .action-buttons .btn {
            width: 100%;
            margin: 0.25rem 0;
        }

        .table td {
            min-width: 150px;
        }

        .description-text {
            max-width: 150px;
        }
    }
</style>