@{
    ViewData["Title"] = "Admin Dashboard - Fodan Artistry";
    var recentOrders = ViewBag.RecentOrders as IEnumerable<FodanArtistry.Application.DTOs.OrderModel.RecentOrderDto>
                       ?? new List<FodanArtistry.Application.DTOs.OrderModel.RecentOrderDto>();
    var orderSummary = ViewBag.OrderSummary as FodanArtistry.Application.Services.DashboardOrderSummaryDto;
    var categories = ViewBag.Categories as IEnumerable<FodanArtistry.Application.DTOs.CategoryModel.CategoryWithCountDto>
                     ?? new List<FodanArtistry.Application.DTOs.CategoryModel.CategoryWithCountDto>();
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="display-6 fw-bold">Welcome back, Admin</h2>
            <p class="text-muted">Here's what's happening with your gallery today.</p>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-lg hover-lift">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="stat-icon bg-primary bg-opacity-10 text-primary rounded-circle p-3">
                                <i class="bi bi-people fs-2"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Total Users</h6>
                            <h3 class="fw-bold mb-0">@ViewBag.TotalUsers</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-lg hover-lift">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="stat-icon bg-success bg-opacity-10 text-success rounded-circle p-3">
                                <i class="bi bi-palette fs-2"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Total Artworks</h6>
                            <h3 class="fw-bold mb-0">@ViewBag.TotalArtworks</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-lg hover-lift">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="stat-icon bg-info bg-opacity-10 text-info rounded-circle p-3">
                                <i class="bi bi-cart fs-2"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Today's Orders</h6>
                            <h3 class="fw-bold mb-0">@orderSummary?.TodayCount</h3>
                            <small class="text-success">@orderSummary?.TodayRevenue.ToString("C")</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-lg hover-lift">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="stat-icon bg-warning bg-opacity-10 text-warning rounded-circle p-3">
                                <i class="bi bi-hourglass-split fs-2"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Pending Orders</h6>
                            <h3 class="fw-bold mb-0">@orderSummary?.PendingCount</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Recent Orders -->
        <div class="col-xl-8">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0">Recent Orders</h5>
                        <a asp-action="Orders" class="btn btn-sm btn-primary rounded-pill px-4">
                            View All <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="bg-light">
                                <tr>
                                    <th>Order #</th>
                                    <th>Customer</th>
                                    <th>Items</th>
                                    <th>Total</th>
                                    <th>Status</th>
                                    <th>Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in recentOrders.Take(5))
                                {
                                    <tr>
                                        <td><span class="fw-semibold">@order.OrderNumber</span></td>
                                        <td>
                                            <div>
                                                <div class="fw-semibold">@order.CustomerName</div>
                                                <small class="text-muted">@order.CustomerEmail</small>
                                            </div>
                                        </td>
                                        <td>@order.ItemCount</td>
                                        <td class="fw-bold text-primary">@order.TotalAmount.ToString("C")</td>
                                        <td>
                                            <span class="badge bg-@order.StatusColor px-3 py-2 rounded-pill">
                                                @order.OrderStatus
                                            </span>
                                        </td>
                                        <td><small class="text-muted">@order.TimeAgo</small></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Categories Summary -->
        <div class="col-xl-4">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0">Categories</h5>
                        <a asp-action="Categories" class="btn btn-sm btn-outline-primary rounded-pill px-4">
                            Manage <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
                <div class="card-body p-4">
                    <ul class="list-group list-group-flush">
                        @foreach (var category in categories)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <div>
                                    <span class="fw-semibold">@category.Name</span>
                                    @if (!string.IsNullOrEmpty(category.CoverImageUrl))
                                    {
                                        <small class="d-block text-muted">Latest: @category.LatestArtworkDate?.ToString("MMM dd")</small>
                                    }
                                </div>
                                <div>
                                    <span class="badge bg-primary rounded-pill me-2">@category.ArtworkCount</span>
                                    <span class="badge bg-success rounded-pill">@category.AvailableArtworkCount available</span>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .stat-icon {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .hover-lift {
        transition: transform 0.3s;
    }
    
        .hover-lift:hover {
            transform: translateY(-5px);
        }
</style>