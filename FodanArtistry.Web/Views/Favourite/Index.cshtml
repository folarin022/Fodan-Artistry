@model IEnumerable<FodanArtistry.Application.DTOs.ArtworkModel.ArtworkDto>
@{
    ViewData["Title"] = "My Favorites";
}

<!-- Hero Section -->
<section class="favorites-hero mb-5">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold gradient-text mb-3">My Collection</h1>
                <p class="lead text-muted">Your personally curated gallery of beloved artworks</p>
            </div>
        </div>
    </div>
</section>

@if (!Model.Any())
{
    <!-- Empty State - Premium Design -->
    <div class="container">
        <div class="empty-state-card text-center py-5">
            <div class="empty-state-icon mb-4">
                <i class="bi bi-heart"></i>
                <i class="bi bi-heart-fill text-primary"></i>
                <i class="bi bi-heart"></i>
            </div>
            <h2 class="display-6 fw-bold mb-3">Your heart is empty</h2>
            <p class="text-muted lead mb-4">Start collecting your favorite artworks today</p>
            <a asp-controller="Artwork" asp-action="Gallery" class="btn btn-primary btn-lg rounded-pill px-5 py-3">
                <i class="bi bi-compass me-2"></i>Explore Gallery
            </a>
            
            <!-- Inspiration Cards -->
            <div class="inspiration-section mt-5 pt-4">
                <h5 class="fw-semibold mb-4">Popular categories you might like</h5>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <span class="category-pill">🎨 Paintings</span>
                    <span class="category-pill">🖼️ Abstract</span>
                    <span class="category-pill">🌅 Landscapes</span>
                    <span class="category-pill">✍️ Sketches</span>
                    <span class="category-pill">🎭 Portraits</span>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="container">
        <!-- Favorites Stats -->
        <div class="favorites-stats mb-4">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="fw-semibold mb-0">
                        <i class="bi bi-heart-fill text-danger me-2"></i>
                        You have <span class="text-primary">@Model.Count()</span> favorite @(Model.Count() == 1 ? "artwork" : "artworks")
                    </h5>
                </div>
                <div class="col-md-6 text-md-end">
                    <div class="view-options">
                        <button class="btn btn-outline-secondary btn-sm rounded-pill active" data-view="grid">
                            <i class="bi bi-grid-3x3-gap-fill"></i>
                        </button>
                        <button class="btn btn-outline-secondary btn-sm rounded-pill" data-view="list">
                            <i class="bi bi-list-ul"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Favorites Grid -->
        <div class="row g-4 favorites-grid">
            @foreach (var artwork in Model)
            {
                <div class="col-md-6 col-lg-4 col-xl-3 favorite-item">
                    <div class="favorite-card">
                        <!-- Card Image -->
                        <div class="card-image-wrapper">
                            <img src="@artwork.ImageUrl" class="card-image" alt="@artwork.Title"
                                 onerror="this.src='/images/placeholder.jpg'">
                            
                            <!-- Quick Action Buttons -->
                            <div class="card-actions">
                                <a asp-controller="Artwork" asp-action="Details" asp-route-id="@artwork.Id" 
                                   class="action-btn view-btn" title="View Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form asp-action="Remove" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="artworkId" value="@artwork.Id" />
                                    <button type="submit" class="action-btn remove-btn" 
                                            title="Remove from favorites"
                                            onclick="return confirm('Remove from favorites?')">
                                        <i class="bi bi-heart-fill"></i>
                                    </button>
                                </form>
                            </div>
                            
                            <!-- Availability Badge -->
                            @if (!artwork.IsAvailable)
                            {
                                <div class="sold-badge">Sold</div>
                            }
                        </div>

                        <!-- Card Content -->
                        <div class="card-content">
                            <h5 class="artwork-title">@artwork.Title</h5>
                            <p class="artwork-artist">by @artwork.ArtistName</p>
                            
                            <div class="artwork-details">
                                <span class="artwork-category">
                                    <i class="bi bi-tag"></i> @artwork.CategoryName
                                </span>
                                <span class="artwork-price">@artwork.Price.ToString("C")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Share Collection Section -->
        <div class="share-collection mt-5 p-4 bg-light rounded-4">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h5 class="fw-semibold mb-2">Share your collection</h5>
                    <p class="text-muted mb-md-0">Let others see your curated taste in art</p>
                </div>
                <div class="col-md-4 text-md-end">
                    <button class="btn btn-outline-primary rounded-pill px-4 me-2" onclick="copyCollectionLink()">
                        <i class="bi bi-link-45deg me-2"></i>Copy Link
                    </button>
                    <button class="btn btn-primary rounded-pill px-4" onclick="shareOnSocial()">
                        <i class="bi bi-share me-2"></i>Share
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Grid/List view toggle
        document.querySelectorAll('[data-view]').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('[data-view]').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                
                const view = this.dataset.view;
                const grid = document.querySelector('.favorites-grid');
                
                if (view === 'grid') {
                    grid.className = 'row g-4 favorites-grid';
                    document.querySelectorAll('.favorite-item').forEach(item => {
                        item.className = 'col-md-6 col-lg-4 col-xl-3 favorite-item';
                    });
                } else {
                    grid.className = 'favorites-list';
                    document.querySelectorAll('.favorite-item').forEach(item => {
                        item.className = 'col-12 favorite-item';
                    });
                }
            });
        });

        // Share functionality
        function copyCollectionLink() {
            const dummy = document.createElement('input');
            dummy.value = window.location.href;
            document.body.appendChild(dummy);
            dummy.select();
            document.execCommand('copy');
            document.body.removeChild(dummy);
            
            showToast('Collection link copied to clipboard!', 'success');
        }

        function shareOnSocial() {
            if (navigator.share) {
                navigator.share({
                    title: 'My Art Collection',
                    text: 'Check out my favorite artworks on Fodan Artistry!',
                    url: window.location.href
                });
            } else {
                copyCollectionLink();
            }
        }

        // Toast notification
        function showToast(message, type = 'success') {
            const toastContainer = document.querySelector('.toast-container') || createToastContainer();
            const toast = document.createElement('div');
            toast.className = `toast-message ${type}`;
            toast.innerHTML = `
                <i class="bi bi-${type === 'success' ? 'check-circle-fill' : 'exclamation-circle-fill'}"></i>
                <span>${message}</span>
            `;
            toastContainer.appendChild(toast);
            
            setTimeout(() => {
                toast.style.animation = 'slideOut 0.3s ease forwards';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function createToastContainer() {
            const container = document.createElement('div');
            container.className = 'toast-container';
            document.body.appendChild(container);
            return container;
        }

        // Hover animations for cards
        document.querySelectorAll('.favorite-card').forEach(card => {
            card.addEventListener('mouseenter', function() {
                const img = this.querySelector('.card-image');
                img.style.transform = 'scale(1.1)';
            });
            
            card.addEventListener('mouseleave', function() {
                const img = this.querySelector('.card-image');
                img.style.transform = 'scale(1)';
            });
        });
    </script>
}

<style>
    .gradient-text {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .favorites-hero {
        padding: 2rem 0 1rem;
    }

    /* Empty State */
    .empty-state-card {
        max-width: 600px;
        margin: 0 auto;
        padding: 4rem 2rem !important;
        background: white;
        border-radius: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .empty-state-icon {
        position: relative;
        display: inline-block;
    }

    .empty-state-icon i {
        font-size: 4rem;
        margin: 0 0.5rem;
        animation: heartBeat 1.5s infinite;
    }

    .empty-state-icon i:nth-child(2) {
        font-size: 5rem;
        animation-delay: 0.2s;
    }

    @@keyframes heartBeat {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }

    .category-pill {
        padding: 0.5rem 1.5rem;
        background: white;
        border: 2px solid #e9ecef;
        border-radius: 50px;
        color: #6c757d;
        font-weight: 500;
        transition: all 0.3s;
        cursor: pointer;
    }

    .category-pill:hover {
        border-color: #667eea;
        color: #667eea;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(102,126,234,0.2);
    }

    /* Favorites Grid */
    .favorites-stats {
        background: white;
        padding: 1.5rem;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

    .view-options .btn {
        width: 40px;
        height: 40px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-left: 0.5rem;
    }

    .view-options .btn.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-color: transparent;
    }

    /* Favorite Card */
    .favorite-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        transition: all 0.3s;
        height: 100%;
        position: relative;
    }

    .favorite-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(102,126,234,0.15);
    }

    .card-image-wrapper {
        position: relative;
        overflow: hidden;
        height: 250px;
    }

    .card-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s;
    }

    .card-actions {
        position: absolute;
        top: 1rem;
        right: 1rem;
        display: flex;
        gap: 0.5rem;
        opacity: 0;
        transform: translateY(-10px);
        transition: all 0.3s;
    }

    .favorite-card:hover .card-actions {
        opacity: 1;
        transform: translateY(0);
    }

    .action-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.3s;
        background: white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        color: #6c757d;
    }

    .action-btn:hover {
        transform: scale(1.1);
    }

    .view-btn:hover {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .remove-btn:hover {
        background: #dc3545;
        color: white;
    }

    .sold-badge {
        position: absolute;
        bottom: 1rem;
        left: 1rem;
        background: rgba(220, 53, 69, 0.9);
        color: white;
        padding: 0.25rem 1rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        backdrop-filter: blur(5px);
    }

    .card-content {
        padding: 1.5rem;
    }

    .artwork-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.25rem;
        color: #2d3748;
    }

    .artwork-artist {
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 1rem;
    }

    .artwork-details {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .artwork-category {
        color: #6c757d;
        font-size: 0.85rem;
    }

    .artwork-category i {
        color: #667eea;
    }

    .artwork-price {
        font-weight: 700;
        color: #2d3748;
    }

    /* List View */
    .favorites-list .favorite-item {
        width: 100%;
    }

    .favorites-list .favorite-card {
        display: flex;
        flex-direction: row;
        height: 200px;
    }

    .favorites-list .card-image-wrapper {
        width: 200px;
        height: 100%;
    }

    .favorites-list .card-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    /* Share Section */
    .share-collection {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border: 1px solid rgba(102,126,234,0.1);
    }

    /* Toast Notifications */
    .toast-container {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
    }

    .toast-message {
        background: white;
        border-left: 4px solid;
        padding: 1rem 1.5rem;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        margin-bottom: 0.5rem;
        animation: slideIn 0.3s ease;
        display: flex;
        align-items: center;
        gap: 1rem;
        min-width: 300px;
    }

    .toast-message.success {
        border-left-color: #10b981;
    }

    .toast-message i {
        font-size: 1.2rem;
    }

    .toast-message.success i {
        color: #10b981;
    }

    @@keyframes slideIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @@keyframes slideOut {
        from {
            transform: translateX(0);
            opacity: 1;
        }
        to {
            transform: translateX(100%);
            opacity: 0;
        }
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .favorites-list .favorite-card {
            flex-direction: column;
            height: auto;
        }

        .favorites-list .card-image-wrapper {
            width: 100%;
            height: 200px;
        }

        .favorites-stats .col-md-6 {
            text-align: center !important;
            margin-top: 1rem;
        }

        .share-collection .col-md-8,
        .share-collection .col-md-4 {
            text-align: center !important;
        }

        .share-collection .btn {
            margin: 0.25rem;
        }
    }
</style>