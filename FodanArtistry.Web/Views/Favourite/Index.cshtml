@model IEnumerable<FodanArtistry.Application.DTOs.ArtworkModel.ArtworkDto>
@{
    ViewData["Title"] = "My Favorites - Fodan Artistry";
}

<div class="container py-4">
    <h2 class="mb-4">My Favorite Artworks</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-heart display-1 text-muted"></i>
            <h4 class="mt-3">No favorites yet</h4>
            <p class="text-muted">Browse the gallery and add some artworks to your favorites</p>
            <a asp-controller="Artwork" asp-action="Gallery" class="btn btn-primary mt-3">
                Browse Gallery
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var artwork in Model)
            {
                <div class="col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 shadow-sm">
                        <img src="@artwork.ImageUrl" class="card-img-top" alt="@artwork.Title" style="height: 200px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title">@artwork.Title</h5>
                            <p class="card-text text-muted">by @artwork.ArtistName</p>
                            <p class="card-text">@artwork.Price.ToString("C")</p>
                        </div>
                        <div class="card-footer bg-transparent d-flex justify-content-between">
                            <a asp-controller="Artwork" asp-action="Details" asp-route-id="@artwork.Id"
                                   class="btn btn-sm btn-outline-primary">
                                View
                            </a>
                            <form asp-action="Remove" method="post" style="display: inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="artworkId" value="@artwork.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Remove from favorites?')">
                                    <i class="bi bi-heart-fill"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>