@model FodanArtistry.Application.DTOs.OrderModel.CreateOrderDto
@{
    ViewData["Title"] = "Secure Checkout - Fodan Artistry";
}

<!-- Progress Bar -->
<div class="bg-light py-4">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="checkout-progress d-flex justify-content-between">
                    <div class="progress-step active">
                        <div class="step-circle">1</div>
                        <span class="step-label">Review Cart</span>
                    </div>
                    <div class="progress-step active">
                        <div class="step-circle">2</div>
                        <span class="step-label">Checkout</span>
                    </div>
                    <div class="progress-step">
                        <div class="step-circle">3</div>
                        <span class="step-label">Confirmation</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row g-5">
        <!-- Checkout Form -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h4 class="fw-bold mb-0">Billing Information</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Checkout" method="post" id="checkoutForm">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <!-- Customer Info -->
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="CustomerName" class="form-label fw-semibold">Full Name</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-person"></i></span>
                                    <input asp-for="CustomerName" class="form-control form-control-lg" placeholder="John Doe" />
                                </div>
                                <span asp-validation-for="CustomerName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CustomerEmail" class="form-label fw-semibold">Email Address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-envelope"></i></span>
                                    <input asp-for="CustomerEmail" class="form-control form-control-lg" type="email" placeholder="john@example.com" />
                                </div>
                                <span asp-validation-for="CustomerEmail" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-telephone"></i></span>
                                    <input asp-for="PhoneNumber" class="form-control form-control-lg" placeholder="+1 234 567 8900" />
                                </div>
                            </div>
                        </div>

                        <!-- Shipping Address -->
                        <h5 class="fw-bold mb-3">Shipping Address</h5>
                        <div class="mb-4">
                            <textarea asp-for="ShippingAddress" class="form-control form-control-lg" rows="3"
                                      placeholder="Street address, city, state, ZIP code"></textarea>
                        </div>

                        <!-- Payment Method -->
                        <h5 class="fw-bold mb-3">Payment Method</h5>
                        <div class="payment-methods mb-4">
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="paymentMethod" id="card" checked>
                                <label class="form-check-label fw-semibold" for="card">
                                    <i class="bi bi-credit-card me-2"></i>Credit / Debit Card
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="paymentMethod" id="paypal">
                                <label class="form-check-label fw-semibold" for="paypal">
                                    <i class="bi bi-paypal me-2"></i>PayPal
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="paymentMethod" id="bank">
                                <label class="form-check-label fw-semibold" for="bank">
                                    <i class="bi bi-bank me-2"></i>Bank Transfer
                                </label>
                            </div>
                        </div>

                        <!-- Hidden fields for order items -->
                        @for (int i = 0; i < Model.OrderItems.Count; i++)
                        {
                            <input type="hidden" name="OrderItems[@i].ArtworkId" value="@Model.OrderItems[i].ArtworkId" />
                            <input type="hidden" name="OrderItems[@i].ArtworkTitle" value="@Model.OrderItems[i].ArtworkTitle" />
                            <input type="hidden" name="OrderItems[@i].UnitPrice" value="@Model.OrderItems[i].UnitPrice" />
                            <input type="hidden" name="OrderItems[@i].Quantity" value="@Model.OrderItems[i].Quantity" />
                        }

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg py-3 rounded-pill">
                                <i class="bi bi-lock-fill me-2"></i>Complete Secure Checkout
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Order Summary -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-lg sticky-top" style="top: 2rem;">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h4 class="fw-bold mb-0">Your Order</h4>
                </div>
                <div class="card-body p-4">
                    @if (Model.OrderItems != null && Model.OrderItems.Any())
                    {
                        @foreach (var item in Model.OrderItems)
                        {
                            <div class="d-flex align-items-center mb-4">
                                <div class="flex-shrink-0">
                                    <div class="bg-light rounded-3 p-2">
                                        <i class="bi bi-image fs-3 text-primary"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <h6 class="fw-bold mb-1">@item.ArtworkTitle</h6>
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted small">Qty: @item.Quantity</span>
                                        <span class="fw-bold text-primary">@item.Subtotal.ToString("C")</span>
                                    </div>
                                </div>
                            </div>
                        }
                        
                        <hr class="my-4">
                        
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal:</span>
                            <span class="fw-semibold">@Model.OrderItems.Sum(i => i.Subtotal).ToString("C")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Shipping:</span>
                            <span class="fw-semibold text-success">Free</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Tax (7.5%):</span>
                            <span class="fw-semibold">@(Model.OrderItems.Sum(i => i.Subtotal * 0.075m).ToString("C"))</span>
                        </div>
                        
                        <hr class="my-4">
                        
                        <div class="d-flex justify-content-between">
                            <span class="h5 fw-bold">Total:</span>
                            <span class="h4 fw-bold text-primary">
                                @{
                                    var subtotal = Model.OrderItems.Sum(i => i.Subtotal);
                                    var tax = subtotal * 0.075m;
                                    var total = subtotal + tax;
                                }
                                @total.ToString("C")
                            </span>
                        </div>
                        
                        <div class="mt-4">
                            <div class="alert alert-success d-flex align-items-center" role="alert">
                                <i class="bi bi-shield-check fs-4 me-2"></i>
                                <div>
                                    <strong>Secure Checkout</strong><br>
                                    <small>Your payment information is encrypted and secure.</small>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-cart-x display-1 text-muted"></i>
                            <p class="mt-3">Your cart is empty</p>
                            <a asp-controller="Artwork" asp-action="Gallery" class="btn btn-primary rounded-pill">
                                Browse Gallery
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Form validation enhancement
        $('#checkoutForm').submit(function(e) {
            if (!$(this).valid()) {
                e.preventDefault();
                // Scroll to first error
                $('html, body').animate({
                    scrollTop: $('.field-validation-error').first().offset().top - 100
                }, 500);
            }
        });
    </script>
}

<style>
    .checkout-progress {
        position: relative;
        padding: 20px 0;
    }
    
        .checkout-progress::before {
            content: '';
            position: absolute;
            top: 35px;
            left: 0;
            right: 0;
            height: 2px;
            background: #e9ecef;
            z-index: 1;
        }
    
    .progress-step {
        position: relative;
        z-index: 2;
        text-align: center;
        flex: 1;
    }
    
    .step-circle {
        width: 50px;
        height: 50px;
        background: #e9ecef;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 10px;
        font-weight: bold;
        color: #6c757d;
        transition: all 0.3s;
    }
    
    .progress-step.active .step-circle {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }
    
    .step-label {
        font-size: 0.9rem;
        color: #6c757d;
    }
    
    .progress-step.active .step-label {
        color: #667eea;
        font-weight: 600;
    }
    
    .input-group-text {
        border: none;
        border-radius: 10px 0 0 10px;
    }
    
    .form-control-lg {
        border: 2px solid #e9ecef;
        border-radius: 0 10px 10px 0;
        padding: 0.75rem 1rem;
    }
    
        .form-control-lg:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }
    
    .payment-methods .form-check {
        padding: 1rem;
        border: 2px solid #e9ecef;
        border-radius: 10px;
        transition: all 0.3s;
    }
    
        .payment-methods .form-check:hover {
            border-color: #667eea;
            background: #f8f9ff;
        }
    
    .payment-methods .form-check-input:checked + .form-check-label {
        color: #667eea;
        font-weight: 600;
    }
</style>