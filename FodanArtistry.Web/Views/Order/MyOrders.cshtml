@model IEnumerable<FodanArtistry.Application.DTOs.OrderModel.OrderDto>
@{
    ViewData["Title"] = "My Orders - Fodan Artistry";
}

<div class="container py-4">
    <h2 class="mb-4">My Orders</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-box display-1 text-muted"></i>
            <h4 class="mt-3">No orders yet</h4>
            <p class="text-muted">Browse our gallery and place your first order</p>
            <a asp-controller="Artwork" asp-action="Gallery" class="btn btn-primary mt-3">
                Browse Gallery
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var order in Model)  // ✅ Model is already IEnumerable<OrderDto>
            {
                <div class="col-12 mb-3">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div>
                                <strong>Order #@order.OrderNumber</strong>
                                <span class="text-muted ms-3">@order.OrderDate.ToString("MMMM dd, yyyy")</span>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-8">
                                    <h6>Items:</h6>
                                    <ul class="list-unstyled">
                                        @foreach (var item in order.Items)  
                                        {
                                            <li>@item.Quantity x @item.ArtworkTitle - @item.Subtotal.ToString("C")</li>
                                        }
                                    </ul>
                                </div>
                                <div class="col-md-4 text-end">
                                    <h5>Total: @order.TotalAmount.ToString("C")</h5>
                                    @if (order.Status == "Pending")
                                    {
                                        <form asp-action="Cancel" method="post" class="mt-3">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                                    onclick="return confirm('Cancel this order?')">
                                                Cancel Order
                                            </button>
                                        </form>
                                    }
                                    <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-outline-primary btn-sm mt-2">
                                        View Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>