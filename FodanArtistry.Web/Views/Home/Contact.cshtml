                            <i class="bi bi-geo-alt-fill text-primary"></i>
                        </div>
                    </div>
                    <h5 class="fw-bold mb-3">Visit Our Gallery</h5>
                    <p class="text-muted mb-3">50 Seidu Toriola Street<br>Lagos, Nigeria</p>
                    <a href="https://maps.google.com/?q=50+Seidu+Toriola+Street+Lagos+Nigeria" 
                       target="_blank" 
                       class="btn btn-outline-primary rounded-pill btn-sm stretched-link">
                        <i class="bi bi-box-arrow-up-right me-2"></i>Get Directions
                    </a>
                </div>
            </div>

            <!-- Email Card -->
            <div class="col-md-6 col-lg-3">
                <div class="contact-card text-center p-4 h-100">
                    <div class="contact-icon-wrapper mb-4">
                        <div class="contact-icon bg-success bg-opacity-10">
                            <i class="bi bi-envelope-fill text-success"></i>
                        </div>
                    </div>
                    <h5 class="fw-bold mb-3">Email Us</h5>
                    <p class="text-muted mb-3">
                        info@fodanartistry.com<br>
                        support@fodanartistry.com
                    </p>
                    <a href="mailto:info@fodanartistry.com?subject=Inquiry%20from%20Website" 
                       class="btn btn-outline-success rounded-pill btn-sm">
                        <i class="bi bi-envelope me-2"></i>Send Email
                    </a>
                </div>
            </div>

            <!-- WhatsApp Card -->
            <div class="col-md-6 col-lg-3">
                <div class="contact-card text-center p-4 h-100 whatsapp-card">
                    <div class="contact-icon-wrapper mb-4">
                        <div class="contact-icon bg-success bg-opacity-10" style="color: #25D366;">
                            <i class="bi bi-whatsapp"></i>
                        </div>
                    </div>
                    <h5 class="fw-bold mb-3">WhatsApp</h5>
                    <p class="text-muted mb-3">
                        +234 80 8223 2578<br>
                        +234 91 1605 6771
                    </p>
                    <div class="d-flex gap-2 justify-content-center">
                        <a href="https://wa.me/2348082232578?text=Hello%20Fodan%20Artistry%2C%20I%20have%20a%20question%20about..." 
                           target="_blank" 
                           class="btn btn-success rounded-pill btn-sm px-4">
                            <i class="bi bi-whatsapp me-2"></i>Chat Now
                        </a>
                    </div>
                </div>
            </div>

            <!-- Hours Card -->
            <div class="col-md-6 col-lg-3">
                <div class="contact-card text-center p-4 h-100">
                    <div class="contact-icon-wrapper mb-4">
                        <div class="contact-icon bg-info bg-opacity-10">
                            <i class="bi bi-clock-fill text-info"></i>
                        </div>
                    </div>
                    <h5 class="fw-bold mb-3">Always Available</h5>
                    <p class="text-muted mb-3">
                        24/7 Online Support<br>
                        Instant Responses
                    </p>
                    <div class="availability-badge">
                        <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill">
                            <i class="bi bi-check-circle-fill me-1"></i>Online Now
