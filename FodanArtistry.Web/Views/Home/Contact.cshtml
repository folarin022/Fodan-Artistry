                   class="btn btn-light btn-lg rounded-pill px-5 py-3">
                    <i class="bi bi-whatsapp me-2" style="color: #25D366;"></i>
                    Chat on WhatsApp
                </a>
                <a href="https://wa.me/2349116056771?text=Hello%20Fodan%20Artistry%2C%20I%20have%20a%20question%20about..." 
                   target="_blank" 
