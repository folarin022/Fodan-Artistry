@{
    ViewData["Title"] = "Contact Us";
}

<!-- Hero Section -->
<section class="contact-hero mb-5">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-3 fw-bold gradient-text mb-3">Get in Touch</h1>
                <p class="lead text-muted mb-0">We'd love to hear from you. Choose your preferred way to connect with us.</p>
            </div>
        </div>
    </div>
</section>

<!-- Contact Cards -->
<section class="mb-5">
    <div class="container">
        <div class="row g-4">
            <!-- Visit Us Card -->
