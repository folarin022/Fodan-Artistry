@{
    ViewData["Title"] = "Artist Subscription";
    var userId = ViewBag.UserId as string;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h3>Become an Artist</h3>
                </div>
                <div class="card-body text-center">
                    <p>To become an artist, you need to pay a one-time subscription fee of <strong>₦5,000</strong>.</p>
                    <p>This will unlock the ability to upload and sell your artworks.</p>
                    <form asp-action="ProcessPayment" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@userId" />
                        <div class="mb-3">
                            <label class="form-label">Select Payment Method</label>
                            <select name="paymentMethod" class="form-select" required>
                                <option value="">-- Choose --</option>
                                <option value="card">Credit/Debit Card</option>
                                <option value="bank">Bank Transfer</option>
                                <option value="paystack">Paystack</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-success btn-lg w-100">Pay ₦5,000</button>
                    </form>
                    <div class="mt-3">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-link">Maybe later</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>