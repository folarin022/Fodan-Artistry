@{
    Layout = null; // 👈 THIS REMOVES THE MAIN LAYOUT
    ViewData["Title"] = "Artist Subscription";
    var userId = ViewBag.UserId as string;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fodan Artistry</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
            body {
                background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                padding: 20px;
                margin: 0;
            }

            .gradient-text {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

            .subscription-card {
                background: white;
                border-radius: 30px;
                box-shadow: 0 20px 40px rgba(0,0,0,0.08);
                padding: 2rem;
                transition: transform 0.3s ease;
                max-width: 800px;
                margin: 0 auto;
            }

                .subscription-card:hover {
                    transform: translateY(-5px);
                }

            .subscription-header {
                text-align: center;
                margin-bottom: 2rem;
            }

            .icon-wrapper {
                width: 80px;
                height: 80px;
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 1rem;
                color: white;
                font-size: 2rem;
                box-shadow: 0 10px 20px rgba(102,126,234,0.2);
            }

            .pricing-section {
                text-align: center;
                margin-bottom: 2rem;
            }

            .price-badge {
                display: inline-flex;
                align-items: baseline;
                background: #f8f9fa;
                padding: 1rem 2rem;
                border-radius: 60px;
                margin-bottom: 1.5rem;
            }

            .currency {
                font-size: 1.5rem;
                font-weight: 600;
                color: #2d3748;
                margin-right: 0.25rem;
            }

            .amount {
                font-size: 3rem;
                font-weight: 800;
                color: #2d3748;
                line-height: 1;
            }

            .period {
                font-size: 0.9rem;
                color: #6c757d;
                margin-left: 0.5rem;
            }

            .benefits-list {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
                gap: 1rem;
                text-align: left;
                background: #f8f9fa;
                border-radius: 20px;
                padding: 1.5rem;
            }

            .benefit-item {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                font-size: 0.95rem;
                color: #2d3748;
            }

                .benefit-item i {
                    font-size: 1.2rem;
                }

            .payment-methods {
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
                margin-bottom: 2rem;
                justify-content: center;
            }

            .payment-method-card {
                flex: 1;
                min-width: 150px;
                border: 2px solid #e9ecef;
                border-radius: 15px;
                padding: 1rem;
                text-align: center;
                cursor: pointer;
                transition: all 0.2s;
            }

                .payment-method-card.active {
                    border-color: #667eea;
                    background: #f0f3ff;
                }

            .radio-circle {
                position: relative;
                display: flex;
                justify-content: center;
            }

                .radio-circle input {
                    position: absolute;
                    opacity: 0;
                    cursor: pointer;
                }

                .radio-circle label {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    gap: 0.5rem;
                    cursor: pointer;
                    font-weight: 500;
                    margin-bottom: 0;
                }

                .radio-circle i {
                    font-size: 2rem;
                    color: #6c757d;
                }

            .payment-method-card.active i {
                color: #667eea;
            }

            .btn-pay {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                border: none;
                color: white;
                padding: 1rem;
                font-weight: 600;
                width: 100%;
                border-radius: 50px;
                font-size: 1.1rem;
                transition: all 0.3s;
            }

                .btn-pay:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 10px 30px rgba(102,126,234,0.4);
                }

            .trust-badges {
                margin-top: 2rem;
                text-align: center;
                display: flex;
                justify-content: center;
                gap: 1.5rem;
                font-size: 0.85rem;
                color: #6c757d;
            }

                .trust-badges i {
                    margin-right: 0.25rem;
                }

            .faq-section {
                max-width: 800px;
                margin: 2rem auto 0;
            }

            .accordion-button:not(.collapsed) {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                color: white;
            }

            .accordion-button:focus {
                box-shadow: none;
                border-color: rgba(102,126,234,0.25);
            }

            @@media (max-width: 768px) {
                .payment-methods {
                    flex-direction: column;
                }

                .benefits-list {
                    grid-template-columns: 1fr;
                }

                .trust-badges {
                    flex-direction: column;
                    gap: 0.5rem;
                }
            }
    </style>
</head>
<body>
    <div class="container py-4">
        <div class="subscription-card">
            <div class="subscription-header">
                <div class="icon-wrapper">
                    <i class="bi bi-palette-fill"></i>
                </div>
                <h2 class="fw-bold mb-2">Artist Membership</h2>
                <p class="text-muted">One-time payment • Lifetime access</p>
            </div>

            <div class="pricing-section">
                <div class="price-badge">
                    <span class="currency">₦</span>
                    <span class="amount">5,000</span>
                    <span class="period">one-time</span>
                </div>
                <div class="benefits-list">
                    <div class="benefit-item">
                        <i class="bi bi-check-circle-fill text-success"></i>
                        <span>Upload unlimited artworks</span>
                    </div>
                    <div class="benefit-item">
                        <i class="bi bi-check-circle-fill text-success"></i>
                        <span>Sell your art globally</span>
                    </div>
                    <div class="benefit-item">
                        <i class="bi bi-check-circle-fill text-success"></i>
                        <span>Receive 90% of sales proceeds</span>
                    </div>
                    <div class="benefit-item">
                        <i class="bi bi-check-circle-fill text-success"></i>
                        <span>Featured in our artist spotlight</span>
                    </div>
                    <div class="benefit-item">
                        <i class="bi bi-check-circle-fill text-success"></i>
                        <span>Dedicated support & analytics</span>
                    </div>
                </div>
            </div>

            <form asp-action="ProcessPayment" method="post" id="paymentForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@userId" />

                <div class="payment-methods">
                    <div class="payment-method-card" data-method="card">
                        <div class="radio-circle">
                            <input type="radio" name="paymentMethod" value="card" id="cardMethod" checked />
                            <label for="cardMethod">
                                <i class="bi bi-credit-card-2-front-fill"></i>
                                <span>Credit / Debit Card</span>
                            </label>
                        </div>
                    </div>
                    <div class="payment-method-card" data-method="bank">
                        <div class="radio-circle">
                            <input type="radio" name="paymentMethod" value="bank" id="bankMethod" />
                            <label for="bankMethod">
                                <i class="bi bi-bank2"></i>
                                <span>Bank Transfer</span>
                            </label>
                        </div>
                    </div>
                    <div class="payment-method-card" data-method="paystack">
                        <div class="radio-circle">
                            <input type="radio" name="paymentMethod" value="paystack" id="paystackMethod" />
                            <label for="paystackMethod">
                                <i class="bi bi-paypal"></i>
                                <span>Paystack</span>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-pay">
                        <i class="bi bi-lock-fill me-2"></i>Pay ₦5,000
                    </button>
                    <div class="mt-3 text-center">
                        <a asp-controller="Account" asp-action="Login" class="text-decoration-none">
                            <i class="bi bi-arrow-left me-1"></i>Maybe later
                        </a>
                    </div>
                </div>
            </form>

            <div class="trust-badges">
                <i class="bi bi-shield-check"></i> Secure payment
                <i class="bi bi-credit-card"></i> All major cards
                <i class="bi bi-clock-history"></i> Instant activation
            </div>
        </div>

        <div class="faq-section">
            <h5 class="fw-bold text-center mb-4">Frequently Asked Questions</h5>
            <div class="accordion" id="faqAccordion">
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingOne">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne">
                            What happens after I pay?
                        </button>
                    </h2>
                    <div id="collapseOne" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Your account will be upgraded to Artist immediately. You'll gain access to the upload dashboard and can start selling your art right away.
                        </div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingTwo">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo">
                            Can I cancel and get a refund?
                        </button>
                    </h2>
                    <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Artist membership is a one-time purchase. Refunds are available within 14 days if you haven't uploaded any artwork.
                        </div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingThree">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree">
                            What payment methods are accepted?
                        </button>
                    </h2>
                    <div id="collapseThree" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            We accept Visa, Mastercard, American Express, bank transfers, and Paystack for Nigerian users.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.querySelectorAll('.payment-method-card').forEach(card => {
        card.addEventListener('click', () => {
        const radio = card.querySelector('input[type="radio"]');
        if (radio) radio.checked = true;
        document.querySelectorAll('.payment-method-card').forEach(c => c.classList.remove('active'));
        card.classList.add('active');
        });
        });
        document.querySelector('.payment-method-card[data-method="card"]').classList.add('active');
    </script>
</body>
</html>